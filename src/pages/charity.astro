---
import BaseLayout from '../layouts/BaseLayout.astro';

const BOOKING_URL = 'https://s-iq.co/BookingPortal/dist/?salonid=144ab19c-0032-4459-b79d-126853a7c144&tab=book';
---
<BaseLayout
  title="Charity | Lau Hairdressing"
  description="Lau Hairdressing supports CoCo's Food4Life Foundation to help orphan children in Africa. Read about our LAU Cows and our ongoing commitment to this amazing cause."
>
  <section class="page-header">
    <div class="container">
      <h1 class="page-title">Charity</h1>
      <p class="page-top__subtitle">Supporting CoCo's Food4Life Foundation</p>
    </div>
  </section>

  <!-- IMPACT STATS BANNER (full-bleed dark) -->
  <section class="charity-impact">
    <div class="container">
      <div class="charity-stats">
        <div class="charity-stat">
          <div class="charity-stat__number">£1,000+</div>
          <div class="charity-stat__label">Raised in our first campaign</div>
        </div>
        <div class="charity-stat">
          <div class="charity-stat__number">3</div>
          <div class="charity-stat__label">Dairy cows supplied to Mandela in Uganda</div>
        </div>
        <div class="charity-stat">
          <div class="charity-stat__number">101</div>
          <div class="charity-stat__label">Orphan children receiving daily fresh milk</div>
        </div>
      </div>
    </div>
  </section>

  <!-- OUR STORY (two-col) -->
  <section class="section">
    <div class="container">
      <div class="two-col two-col--align-center">
        <div>
          <h2 class="subheading">Our Story</h2>
          <p>In December 2021, instead of creating a Christmas gift for all our customers, Lau Hairdressing donated <strong>£500</strong> on your behalf to the amazing <strong>CoCo's Food4Life Foundation</strong> — helping to raise funds for orphaned children in Africa who are unable to help themselves.</p>
          <p>Our initial target was to reach £1,000. Thanks to the incredible generosity of our customers, we've now comfortably exceeded that. Thank you to everyone who has already donated.</p>
          <p>On Saturday 5th February 2022, we raised enough money for Mandela in Uganda to purchase three cows — two of which were pregnant. These lovely animals now supply daily fresh milk to the 101 orphan children in his care.</p>
        </div>
        <div class="charity-logo">
          <img src="/images/charity/cocos-logo.png" alt="CoCo's Food4Life Foundation" />
        </div>
      </div>
    </div>
  </section>

  <!-- LAU COWS FEATURE (full-bleed dark) -->
  <section class="charity-cows">
    <div class="container">
      <div class="charity-cows__inner">
        <div class="charity-cows__image">
          <img src="/images/charity/lau-cow.gif" alt="The LAU Cows — Laura, Amy and Usher" />
        </div>
        <div class="charity-cows__copy">
          <h2 class="subheading charity-cows__eyebrow">Meet the team</h2>
          <h3 class="charity-cows__title">The LAU Cows</h3>
          <p class="charity-cows__names"><strong>L</strong>aura &nbsp;·&nbsp; <strong>A</strong>my &nbsp;·&nbsp; <strong>U</strong>sher</p>
          <p>Please help us continue funding the Food4Life program so these beautiful animals keep producing milk for the children in Uganda. Share this page with friends and family — together we really can change children's lives.</p>
          <p class="charity-cows__signature">Damon, Lisa &amp; The Team x</p>
        </div>
      </div>
    </div>
  </section>

  <!-- NEW ARRIVAL UPDATE -->
  <section class="section">
    <div class="container">
      <div class="charity-update">
        <div class="charity-update__badge">Latest news · May 2022</div>
        <h2 class="charity-update__title">Welcome to the family</h2>
        <p class="charity-update__lead">A new baby Lau Cow was born on the 8th of May 2022 — another set of little hooves helping Mandela's children thrive.</p>
        <div class="charity-update__image">
          <img src="/images/charity/baby-cow.png" alt="New baby Lau cow born May 2022" />
        </div>
        <div class="btn-group btn-group--center">
          <a href={BOOKING_URL} class="btn btn--primary" target="_blank" rel="noopener">Book now</a>
          <a href="/contact.html" class="btn btn--outline">Contact the salon</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
