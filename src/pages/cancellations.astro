---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Cancellation Policy | Lau Hairdressing"
  description="Lau Hairdressing cancellation policy — 48 hours notice required for cancellations or rebookings to avoid deposit loss."
>
  <section class="page-header">
    <div class="container">
      <h1 class="page-title">Our Cancellation Policy</h1>
    </div>
  </section>

  <section class="section">
    <div class="container legal-body">
      <p class="lead-text">It happens to all of us! Just a quick note that due to high demand, the salon requires 48hrs notice for any cancellations or rebookings to avoid the loss of any deposits made.</p>

      <p class="lead-text mt-3">We look forward to welcoming you and to working together to make your visit as special as it should be.</p>

      <p class="lead-text text-italic mt-3">Thank you<br />Damon x</p>
    </div>
  </section>
</BaseLayout>
