---
// ALTERNATIVE microblading page — identical to /microblading.html but with
// a taller hero (720px max instead of 520px), giving the Tamlin portrait
// much more visual presence. Preserved as a separate URL so Matt can show
// both options to Damon and pick.
//
// Everything else is identical to microblading.astro.
import BaseLayout from '../layouts/BaseLayout.astro';

const BOOKING_URL = 'https://s-iq.co/BookingPortal/dist/?salonid=144ab19c-0032-4459-b79d-126853a7c144&tab=book';
---
<BaseLayout
  title="Microblading Kent | Tamlin Lau at Lau Hairdressing (Tall hero variant)"
  description="Discover affordable microblading services starting at £300, including 6-week infills. Ideal for over-plucked, sparse, or non-existent eyebrows. Our treatment offers realistic hair strokes for a natural look, reshaping and adding volume to your brows. Enjoy long-lasting results up to 12 months. Say goodbye to daily makeup routines"
>
  <!-- FLOATING VARIANT BADGE so Matt can visually distinguish this page -->
  <div style="position:fixed;top:84px;right:20px;z-index:999;background:#B09F65;color:#fff;padding:8px 14px;font-family:Montserrat,sans-serif;font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;box-shadow:0 2px 8px rgba(0,0,0,0.2);">
    Tall hero variant
  </div>

  <div class="page-top">
    <!-- HERO: salon-hero pattern with --tall modifier for portrait height -->
    <section class="salon-hero salon-hero--tall">
      <div class="salon-hero__carousel" data-carousel>
        <div class="salon-hero__slides" data-carousel-track>
          <div class="salon-hero__slide">
            <img src="/images/microblading/tamlin-lau.png" alt="Tamlin Lau, Microblading Artist" />
          </div>
          <div class="salon-hero__slide">
            <img src="/images/microblading/tamlin-lau.png" alt="Tamlin Lau, Microblading Artist" />
          </div>
          <div class="salon-hero__slide">
            <img src="/images/microblading/tamlin-lau.png" alt="Tamlin Lau, Microblading Artist" />
          </div>
        </div>
        <div class="salon-hero__nav">
          <button class="salon-hero__arrow" data-carousel-next aria-label="Next image">&rarr;</button>
          <button class="salon-hero__arrow" data-carousel-prev aria-label="Previous image">&larr;</button>
        </div>
      </div>
      <div class="quote-block">
        <p class="quote-block__text">"Brows frame your face, and with the artist's touch, every glance becomes a statement of confidence and grace."</p>
        <p class="quote-block__author">Tamlin Lau</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h1 class="page-title">Tamlin Lau</h1>
        <h2 class="subheading">Your microblading artist</h2>

        <p>At Lau Hairdressing, our stylists go beyond just creating beautiful hair - they make every visit a warm and welcoming experience. You'll always be greeted with a smile and genuine conversation, as we take the time to listen and understand exactly what you need. We offer honest advice and create hairstyles that not only suit your face shape and lifestyle but are also easy to maintain at home. Passionate about our craft, we stay updated with the latest techniques and products to bring you the best results. Most importantly, we want you to feel completely at ease, enjoy your time with us, and leave feeling 100% happy - every single visit. Meet your experts below.</p>

        <div class="btn-group">
          <a href={BOOKING_URL} class="btn btn--primary" target="_blank" rel="noopener">Book now</a>
          <a href="/visit.html" class="btn btn--outline">Your Visit</a>
        </div>

        <!-- Compare links -->
        <p style="margin-top:3rem;padding-top:2rem;border-top:1px solid #d8d8d8;font-size:0.875rem;color:#454545;">
          <strong>Comparing variants:</strong>&nbsp; you're viewing the <strong>tall</strong> hero variant (720px).&nbsp; <a href="/microblading.html" style="color:#000;">View the standard variant (520px) →</a>
        </p>
      </div>
    </section>
  </div>

  <script is:inline>
    (function() {
      const carousel = document.querySelector('[data-carousel]');
      if (!carousel) return;
      const track = carousel.querySelector('[data-carousel-track]');
      const slides = track.querySelectorAll('.salon-hero__slide');
      const prev = carousel.querySelector('[data-carousel-prev]');
      const next = carousel.querySelector('[data-carousel-next]');
      let i = 0;
      function go(delta) {
        i = (i + delta + slides.length) % slides.length;
        track.style.transform = 'translateX(-' + (i * 100) + '%)';
      }
      next.addEventListener('click', () => go(1));
      prev.addEventListener('click', () => go(-1));
    })();
  </script>
</BaseLayout>
