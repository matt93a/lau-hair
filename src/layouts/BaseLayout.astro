---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileNav from '../components/MobileNav.astro';
import RecruitingBanner from '../components/RecruitingBanner.astro';

// ─── GLOBAL TOGGLE ───────────────────────────────────────────────
// Flip this to true to show the "We're hiring" gold banner sitewide.
// Flip to false to hide it — no code change on any page needed.
const SHOW_RECRUITING_BANNER = true;
// ─────────────────────────────────────────────────────────────────

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  bodyClass?: string;
  headerVariant?: 'default' | 'dark' | 'minimal';
  /** When true, suppress the global Header + MobileNav + Footer (landing page) */
  bareChrome?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage = 'https://www.lau-hair.com/images/hero-bg.png',
  bodyClass,
  headerVariant = 'default',
  bareChrome = false,
} = Astro.props as Props;

const showBanner = !bareChrome && SHOW_RECRUITING_BANNER;

// Derive canonical if not provided: strip .html from pathname, prefix with site
const pathname = Astro.url.pathname.replace(/\/index\.html$/, '/').replace(/\.html$/, '.html');
const fullCanonical = canonical ?? `https://www.lau-hair.com${pathname}`;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={fullCanonical} />
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={fullCanonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Lau Hairdressing" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@lauhairdressing" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@200;300;400;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />

    <!-- Google Analytics 4 (placeholder ID until Matt sets up the GA property) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>

    <slot name="head" />
  </head>
  <body class={[bodyClass, showBanner ? 'has-recruiting-banner' : ''].filter(Boolean).join(' ')}>
    <RecruitingBanner show={showBanner} />
    {!bareChrome && <Header variant={headerVariant} />}
    <slot />
    {!bareChrome && <MobileNav />}
    {!bareChrome && <Footer />}
  </body>
</html>
