---
// Site-wide footer. Edit hours, address, or nav here — reflects on every page.
const PHONE = '01622 670 557';
const ADDRESS = {
  street: "13 Gabriel's Hill",
  city: 'Maidstone',
  county: 'Kent, ME15 6HL',
  country: 'United Kingdom',
};
const MAPS_URL =
  "https://maps.google.com/maps?q=Lau+Hairdressing+Ltd,+Gabriel%27s+Hill,+Maidstone,+United+Kingdom";

const hours = [
  ['Mon', 'Closed'],
  ['Tue', '9:30 - 8pm'],
  ['Wed', '9am - 6pm'],
  ['Thu', '9am - 6pm'],
  ['Fri', '9:30 - 7pm'],
  ['Sat', '8am - 5pm'],
  ['Sun', 'Closed'],
] as const;

const footerNav = [
  { href: '/salon.html',       label: 'Salon' },
  { href: '/visit.html',       label: 'Booking' },
  { href: '/stylists.html',    label: 'Stylists' },
  { href: '/services.html',    label: 'Services' },
  { href: '/microblading.html',label: 'Microblading' },
  { href: '/charity.html',     label: 'Charity' },
  { href: '/terms.html',       label: 'Terms & Conditions' },
  { href: '/privacy.html',     label: 'Privacy & Cookies' },
  { href: '/contact.html',     label: 'Hairdresser Maidstone' },
];
---
<footer class="site-footer">
  <div class="footer-grid">
    <!-- Col 1: Logo + Address -->
    <div class="footer-col">
      <div class="footer-logo">
        <img src="/images/logo-black.svg" alt="Lau Hairdressing" height="50" />
      </div>
      <p><strong>LAU Salon</strong></p>
      <address>
        {ADDRESS.street}<br />
        {ADDRESS.city}<br />
        {ADDRESS.county}<br />
        {ADDRESS.country}
      </address>
      <a href={MAPS_URL} class="btn--map" target="_blank" rel="noopener">Find on a map</a>
    </div>

    <!-- Col 2: Hours -->
    <div class="footer-col">
      <h4>Salon Hours</h4>
      <table class="footer-hours">
        {hours.map(([day, time]) => (
          <tr><td>{day}</td><td>{time}</td></tr>
        ))}
      </table>
    </div>

    <!-- Col 3: Navigation -->
    <div class="footer-col">
      <h4>Navigation</h4>
      <ul class="footer-nav">
        {footerNav.map(item => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Col 4: Guidelines -->
    <div class="footer-col">
      <h4>Salon Guidelines</h4>
      <p>To avoid deposit loss we request a 48 hr cancellation notice.</p>
      <p>Thanks x</p>
    </div>

    <!-- Col 5: Contact -->
    <div class="footer-col footer-contact">
      <h4>Salon Contact</h4>
      <p class="phone">{PHONE}</p>
      <p>to book</p>
      <div class="footer-socials">
        <a href="https://x.com/lauhairdressing" target="_blank" rel="noopener" aria-label="X">
          <svg viewBox="0 0 24 24" fill="#000"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://facebook.com/lausalon" target="_blank" rel="noopener" aria-label="Facebook">
          <svg viewBox="0 0 24 24" fill="#000"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="https://www.instagram.com/lauhairdressing/" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="#000"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
