---
// Service speciality cards — horizontal scroll on desktop, 2-col on mobile.
// 5 cards per Matt's call (kept Perming AND added Men's Grooming).

const SERVICES = [
  { title: 'Balayage & Blonde', sub: 'Specialists in Maidstone',     img: '/images/v2/transform-3.png', href: '/services.html#balayage' },
  { title: 'Haircutting',        sub: 'Precision cuts for women & men', img: '/images/v2/transform-1.png', href: '/services.html#cuts' },
  { title: 'Colour Correction',  sub: 'Experts in Maidstone',           img: '/images/v2/transform-2.png', href: '/services.html#colour' },
  { title: "Men\u2019s Grooming",sub: 'Cuts & beard work',              img: '/images/v2/transform-2.png', href: '/services.html#mens' },
  { title: 'Perming',            sub: 'Modern textured waves',          img: '/images/v2/transform-1.png', href: '/services.html#perming' },
];
---
<section class="section svc-section">
  <div class="container">
    <div class="section-title">
      <div>
        <div class="eyebrow gold" style="margin-bottom: 14px;">Our Specialities</div>
        <h2>What we're known for.</h2>
      </div>
      <p class="lede">A 30-year specialism in colour, cutting and craft. Every chair, every visit — built around you.</p>
    </div>

    <div style="position: relative;">
      <div class="svc-scroll-controls">
        <button class="svc-scroll-btn" id="svc-prev" aria-label="Scroll left">
          <svg width="14" height="10" viewBox="0 0 20 14" fill="none"><path d="M19 7H1m0 0l6-6m-6 6l6 6" stroke="currentColor" stroke-width="1.2"/></svg>
        </button>
        <button class="svc-scroll-btn" id="svc-next" aria-label="Scroll right">
          <svg width="14" height="10" viewBox="0 0 20 14" fill="none"><path d="M1 7h18m0 0l-6-6m6 6l-6 6" stroke="currentColor" stroke-width="1.2"/></svg>
        </button>
      </div>
      <div class="svc-row" id="svc-row">
        {SERVICES.map(s => (
          <a class="svc-card" href={s.href}>
            <div class="svc-card-img-wrap">
              <img class="svc-card-img" src={s.img} alt={s.title} loading="lazy" />
              <div class="svc-card-overlay"></div>
            </div>
            <div class="svc-card-body">
              <div class="svc-card-title">{s.title}</div>
              <div class="svc-card-sub">{s.sub}</div>
              <div class="svc-card-link">View <span>→</span></div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var row = document.getElementById('svc-row');
    if (!row) return;
    document.getElementById('svc-prev').addEventListener('click', function () { row.scrollBy({ left: -380, behavior: 'smooth' }); });
    document.getElementById('svc-next').addEventListener('click', function () { row.scrollBy({ left:  380, behavior: 'smooth' }); });
  })();
</script>
